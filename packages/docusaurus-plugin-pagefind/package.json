{
	"name": "docusaurus-plugin-pagefind",
	"version": "0.2.1",
	"description": "Pagefind search plugin for Docusaurus with DocSearch UI",
	"keywords": [
		"docusaurus",
		"docusaurus-plugin",
		"pagefind",
		"search",
		"static-site"
	],
	"license": "MIT",
	"author": "toasty-kj",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/toasty-kj/docusaurus-plugin-pagefind.git",
		"directory": "packages/docusaurus-plugin-pagefind"
	},
	"homepage": "https://github.com/toasty-kj/docusaurus-plugin-pagefind#readme",
	"bugs": {
		"url": "https://github.com/toasty-kj/docusaurus-plugin-pagefind/issues"
	},
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"files": [
		"dist",
		"src/theme"
	],
	"scripts": {
		"build": "tsc -p tsconfig.json && tsc -p tsconfig.theme.json && cp src/theme/SearchBar/styles.css dist/theme/SearchBar/styles.css",
		"prepublishOnly": "cp ../../README.md ./README.md && cp ../../LICENSE ./LICENSE",
		"test": "vitest run",
		"test:watch": "vitest"
	},
	"dependencies": {
		"fast-glob": "^3.3.0"
	},
	"peerDependencies": {
		"@docsearch/css": ">=3.0.0",
		"@docsearch/react": ">=3.0.0",
		"@docusaurus/core": ">=3.0.0",
		"pagefind": ">=1.1.0",
		"react": ">=18.0.0",
		"react-dom": ">=18.0.0"
	},
	"devDependencies": {
		"@docsearch/css": "^3.0.0",
		"@docsearch/react": "^3.0.0",
		"@docusaurus/module-type-aliases": "^3.10.0",
		"@docusaurus/types": "^3.10.0",
		"@docusaurus/tsconfig": "^3.10.0",
		"@types/node": "^22.0.0",
		"pagefind": "^1.5.2",
		"typescript": "^5.0.0",
		"vitest": "^3.2.6"
	}
}
