{
	"extends": "../../tsconfig.base.json",
	"compilerOptions": {
		// nodenext picks the format per file: .ts stays CJS (no "type" field),
		// .mts is emitted as genuine ESM (pagefindWorker.mts needs this).
		"module": "nodenext",
		"moduleResolution": "nodenext",
		"outDir": "./dist",
		"rootDir": "./src",
		"noEmit": false,
		"types": ["@docusaurus/module-type-aliases", "node"]
	},
	"include": ["src/**/*"],
	"exclude": ["src/**/*.spec.ts", "src/theme/**/*"]
}
